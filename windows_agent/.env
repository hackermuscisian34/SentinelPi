# Windows Agent Configuration

# Pi Server Connection
PI_SERVER_IP=10.253.242.53
PI_SERVER_PORT=8000
PI_SERVER_WEBSOCKET_PORT=8000

# Device Information
DEVICE_HOSTNAME=AUTO
AGENT_VERSION=1.0.0

# Telemetry Settings
TELEMETRY_INTERVAL_SECONDS=30
HEARTBEAT_INTERVAL_SECONDS=60

# Reconnection Settings
RECONNECT_INTERVAL_SECONDS=5
MAX_RECONNECT_ATTEMPTS=0  # 0 = infinite

# Logging
LOG_LEVEL=INFO
LOG_FILE=C:\ProgramData\SentinelPi\agent.log

# Credentials (set after enrollment)
DEVICE_ID=
API_KEY=
